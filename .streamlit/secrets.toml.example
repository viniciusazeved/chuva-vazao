# Copie para .streamlit/secrets.toml localmente (ignorado pelo git).
# Em producao (Streamlit Cloud), cole o conteudo em "App settings -> Secrets".

[gee]
# JSON de service account do GCP com role "Earth Engine Resource Viewer".
# Registre a SA tambem em https://signup.earthengine.google.com/#!/service_accounts
# Cole o JSON INTEIRO entre triplas aspas.
service_account_email = "chuva-vazao@ggeantigravity.iam.gserviceaccount.com"
service_account_key_json = """
{
  "type": "service_account",
  "project_id": "ggeantigravity",
  "private_key_id": "...",
  "private_key": "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",
  "client_email": "chuva-vazao@ggeantigravity.iam.gserviceaccount.com",
  "client_id": "...",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token",
  "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
  "client_x509_cert_url": "..."
}
"""

